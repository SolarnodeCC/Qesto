{
  "workspace": "qesto",
  "tests": {
    "src/": {
      "command": "just ux-qa",
      "purpose": "rendered UX QA for React/Vite frontend",
      "lane": "web"
    },
    "apps/web/": {
      "command": "just ux-qa",
      "purpose": "rendered UX QA for web alias surface",
      "lane": "web"
    },
    "functions/api/": {
      "command": "just fast",
      "purpose": "typecheck, unit tests, and build for Hono API",
      "lane": "fast"
    },
    "worker/": {
      "command": "just fast",
      "purpose": "typecheck and build for scheduled worker",
      "lane": "fast"
    },
    "migrations/": {
      "command": "npm test -- --run tests/unit/migrations",
      "purpose": "migration safety unit tests",
      "lane": "db"
    },
    "schema.sql": {
      "command": "npm test -- --run",
      "purpose": "schema integrity via unit tests",
      "lane": "db"
    },
    "ops/": {
      "command": "just security",
      "purpose": "CI lanes and secret scanning",
      "lane": "security"
    },
    ".github/workflows/": {
      "command": "just security",
      "purpose": "workflow security posture",
      "lane": "security"
    },
    "contracts/": {
      "command": "just check",
      "purpose": "contract drift and typecheck gate",
      "lane": "contract"
    },
    "tests/": {
      "command": "npx playwright test --config tests/playwright.config.ts",
      "purpose": "end-to-end browser tests",
      "lane": "e2e"
    }
  }
}
