# Security headers and short-TTL edge caching for the HTML shell. See ADR-0065.
# Rule ordering matters: later rules win for conflicting headers.
#
# Cache-Control on the shell: s-maxage=60 lets the Cloudflare edge serve index.html
# for up to 60s without an origin round-trip (this is what cuts the ~1.4s TTFB);
# max-age=0 keeps browsers revalidating every load so client staleness stays ~zero;
# stale-while-revalidate=86400 bounds tail latency by serving stale at the edge while
# revalidating in the background. Safe vs. the deploy commit-parity check: that gate
# (scripts/verify-deploy.mjs) only reads /api/version JSON and the local dist build,
# never cached HTML, and CI's purge_everything resets the edge cache each release.
/*
  Cache-Control: public, max-age=0, s-maxage=60, stale-while-revalidate=86400
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' wss: https://qesto.cc https://qesto-api.oostelaar.workers.dev https://cloudflareinsights.com https://*.clarity.ms https://c.bing.com; img-src 'self' data: https://api.qrserver.com https://*.clarity.ms https://c.bing.com; frame-src https://docs.google.com https://*.google.com https://www.canva.com https://canva.com; frame-ancestors 'none'; upgrade-insecure-requests

# Public display pages — allow iframe embedding (e.g. PowerPoint Web Viewer).
# Must come after /* so these headers override the defaults above.
/display/*
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' wss: https://qesto.cc https://qesto-api.oostelaar.workers.dev https://cloudflareinsights.com https://*.clarity.ms https://c.bing.com; img-src 'self' data: https://*.clarity.ms https://c.bing.com; frame-ancestors *; upgrade-insecure-requests

# Hashed assets are immutable — override Cache-Control from /* above.
# Must come after /* so immutable caching wins over no-cache.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/chunks/*
  Cache-Control: public, max-age=31536000, immutable
