{
  "name": "qesto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --port 8787",
    "build": "npm run tokens:build && vite build",
    "preview": "vite preview",
    "deploy:api": "wrangler deploy",
    "deploy:frontend": "npm run build && wrangler pages deploy dist --project-name qesto",
    "tokens:build": "node scripts/build-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage && node scripts/measure-coverage.mjs",
    "test:flaky-check": "node scripts/detect-flaky.mjs",
    "typecheck": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n.mjs"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.2",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser": "^4.1.4",
    "axe-core": "^4.11.3",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
