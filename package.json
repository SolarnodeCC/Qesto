{
  "name": "qesto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "esbuild": "^0.28.1",
    "ws": "^8.21.0",
    "js-yaml": "^4.2.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --port 8787",
    "build": "npm run tokens:build && vite build",
    "preview": "vite preview",
    "deploy:api": "node scripts/deploy-api.mjs",
    "deploy:api:dry-run": "node scripts/deploy-api.mjs --allow-dirty --dry-run",
    "deploy:frontend": "npm run build && wrangler pages deploy dist --project-name qesto",
    "tokens:build": "node scripts/build-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run tests/stress/",
    "test:a11y": "vitest run tests/a11y/",
    "test:eval": "vitest run tests/eval/",
    "e2e:db:local": "wrangler d1 migrations apply qesto_3_db --local",
    "db:local:reset": "bash scripts/reset-local-d1.sh",
    "e2e:serve:fullstack": "wrangler pages dev dist --port 8788 --d1 DB=qesto_3_db --binding JWT_SECRET=dev-secret --binding ENVIRONMENT=development --binding APP_URL=http://localhost:8788 --no-show-interactive-dev-session",
    "typecheck": "tsc --noEmit",
    "check:baseline": "node scripts/check-baseline.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "report:i18n:gaps": "node scripts/i18n-gap-report.mjs",
    "check:design-tokens": "node scripts/check-design-tokens.mjs",
    "check:tokens-drift": "node scripts/check-tokens-drift.mjs",
    "check:contrast-tokens": "node scripts/check-contrast-tokens.mjs",
    "check:pii-log": "bash scripts/check-pii-log.sh",
    "check:compliance-claims": "node scripts/check-compliance-claims.mjs",
    "check:dark-mode": "node scripts/check-marketing-dark-mode.mjs",
    "check:sprint-51-60": "node scripts/check-sprint-51-60-dod.mjs",
    "check:rc": "npm run check:migrations && npm run check:kv-access && npm run check:no-any && npm run typecheck && npm run check:i18n && npm run check:help-seed && npm run check:tokens-drift && npm run check:contrast-tokens && npm run check:baseline && npm test && npm run test:eval && npm run test:a11y && npm run build",
    "perf:audit": "node scripts/perf-audit.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "smoke:platform-v7": "node scripts/smoke-platform-v7.mjs",
    "test:e2e": "playwright test --config tests/playwright.config.ts --project=fullstack-chrome",
    "test:e2e:fullstack": "playwright test --config tests/playwright.config.ts --project=fullstack-chrome",
    "test:e2e:spa": "playwright test --config tests/playwright.config.ts --project=spa-chrome",
    "test:e2e:a11y": "playwright test --config tests/playwright.config.ts --project=a11y-chrome",
    "test:e2e:headed": "playwright test --config tests/playwright.config.ts --headed",
    "test:e2e:chrome": "playwright test --config tests/playwright.config.ts --project=fullstack-chrome",
    "kb:embed": "npx tsx scripts/embed-kb.ts",
    "kb:sync": "npx tsx scripts/kb-sync-cli.ts",
    "kb:health": "npx tsx scripts/kb-health.ts",
    "help:sync": "npx tsx scripts/sync-help-docs.ts",
    "help:seed:build": "node scripts/generate-help-seed.mjs",
    "check:help-seed": "node scripts/generate-help-seed.mjs --check",
    "contracts:generate": "openapi-typescript contracts/openapi/qesto-api.yaml -o contracts/generated/api.d.ts",
    "check:migrations": "node scripts/check-migration-gaps.mjs && node scripts/verify-migration-metadata.mjs",
    "check:kv-access": "node scripts/check-kv-access.mjs",
    "check:no-any": "node scripts/check-no-any.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "hono": "^4.12.26",
    "jankurai-workspace": "github:neverhuman/jankurai#v1.6.10",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-qr-code": "^2.2.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@cloudflare/workers-types": "^4.20260619.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "wrangler": "^4.103.0"
  }
}
