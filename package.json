{
  "name": "qesto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --port 8787",
    "build": "npm run tokens:build && vite build",
    "preview": "vite preview",
    "deploy:api": "wrangler deploy",
    "deploy:frontend": "npm run build && wrangler pages deploy dist --project-name qesto",
    "tokens:build": "node scripts/build-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stress": "vitest run tests/stress/",
    "test:a11y": "vitest run tests/a11y/",
    "e2e:db:local": "wrangler d1 migrations apply qesto-db --local",
    "e2e:serve:fullstack": "wrangler pages dev dist --port 8788 --binding JWT_SECRET=dev-secret --binding ENVIRONMENT=development --binding APP_URL=http://localhost:8788 --no-show-interactive-dev-session",
    "typecheck": "tsc --noEmit",
    "check:baseline": "node scripts/check-baseline.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "report:i18n:gaps": "node scripts/i18n-gap-report.mjs",
    "check:design-tokens": "node scripts/check-design-tokens.mjs",
    "check:tokens-drift": "node scripts/check-tokens-drift.mjs",
    "perf:audit": "node scripts/perf-audit.mjs",
    "verify:deploy": "node scripts/verify:deploy.mjs",
    "test:e2e": "playwright test --project=fullstack-chrome",
    "test:e2e:fullstack": "playwright test --project=fullstack-chrome",
    "test:e2e:spa": "playwright test --project=spa-chrome",
    "test:e2e:a11y": "playwright test --project=a11y-chrome",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chrome": "playwright test --project=fullstack-chrome"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "axe-core": "^4.11.3",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.83.0"
  }
}
