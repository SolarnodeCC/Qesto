# Copy to .env.local for local development overrides.
#
# VITE_API_BASE_URL: Base URL for the Cloudflare Worker API.
# Leave empty in local dev — Vite proxies /api/* to wrangler dev on :8787.
# Set to the Worker URL for production builds or CI.
# Example (production): VITE_API_BASE_URL=https://qesto.cc
VITE_API_BASE_URL=
# Superuser email — grants admin UI access in the frontend.
VITE_SUPERUSER_EMAIL=oostelaar@hotmail.com
# Checkout URL for paid plan upgrades.
VITE_CHECKOUT_URL=https://checkout.qesto.cc
