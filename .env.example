# Copy to .env.local for local development overrides.
#
# VITE_API_BASE_URL: Base URL for the Cloudflare Worker API.
# Leave empty in local dev — Vite proxies /api/* to wrangler dev on :8787.
# Set to the Worker URL for production builds or CI.
# Example (production): VITE_API_BASE_URL=https://qesto-api.oostelaar.workers.dev
VITE_API_BASE_URL=
