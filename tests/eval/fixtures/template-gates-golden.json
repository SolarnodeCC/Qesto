    { "name": "score wrapped in prose still parsed", "response": "Here is the rating: {\"score\": 10} done", "admits": true },
    { "name": "malformed JSON rejects (fail-closed)", "response": "{score: 10", "admits": false },
    { "name": "empty response rejects (fail-closed)", "response": "", "admits": false },
    { "name": "non-numeric score rejects (fail-closed)", "response": "{\"score\": \"low\"}", "admits": false },
