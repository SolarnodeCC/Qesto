    { "name": "hasAny true with empty list still rejects", "response": "{\"nouns\": [], \"hasAny\": true}", "admits": false },
    { "name": "malformed JSON rejects (fail-closed)", "response": "not json at all", "admits": false },
    { "name": "empty response rejects (fail-closed)", "response": "", "admits": false },
