# Pinned GitHub Action SHAs — update via release tags, not floating @v* refs.
# Regenerate: curl https://api.github.com/repos/<owner>/<repo>/git/ref/tags/<tag>
# NOTE: for the gh-aw (agentic workflow) actions, `.github/aw/actions-lock.json`
# is the source of truth — keep these values in sync with what the workflows in
# .github/workflows/*.yml actually reference.
ACTIONS_CHECKOUT_SHA=9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # actions/checkout@v7.0.0
ACTIONS_SETUP_NODE_SHA=48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # actions/setup-node@v6
ACTIONS_UPLOAD_ARTIFACT_SHA=043fb46d1a93c77aae656e7c1c64a875d1fc6a0a # actions/upload-artifact@v7
ACTIONS_GITHUB_SCRIPT_SHA=3a2844b7e9c422d3c10d287c895573f7108da1b3 # actions/github-script@v9.0.0
SLACK_GITHUB_ACTION_SHA=0d95c9a7becc1e6e297d76df9bc735c44f4cbcbc # slackapi/slack-github-action@v3
