{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Qesto User Story Schema",
  "description": "Canonical format for user stories in docs/BACKLOG.md and docs/SPRINT_PLAN.md",
  "type": "object",
  "required": ["id", "title", "points", "as_a", "i_want", "so_that", "acceptance_criteria"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]{3,4}$",
      "description": "Story ID (e.g., SES-001, BUG-005, FEATURE-010)"
    },
    "title": {
      "type": "string",
      "maxLength": 100,
      "description": "Brief one-line title"
    },
    "points": {
      "type": "integer",
      "enum": [1, 2, 3, 5, 8, 13],
      "description": "Fibonacci story points"
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"],
      "description": "Priority level (P0=blocker, P1=critical, P2=high, P3=low)"
    },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "ready_for_review", "closed"],
      "description": "Current status"
    },
    "as_a": {
      "type": "string",
      "maxLength": 200,
      "description": "User role (e.g., 'session facilitator', 'team admin')"
    },
    "i_want": {
      "type": "string",
      "maxLength": 200,
      "description": "Capability desired"
    },
    "so_that": {
      "type": "string",
      "maxLength": 200,
      "description": "Business value or benefit"
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["given", "when", "then"],
        "properties": {
          "given": {
            "type": "string",
            "description": "Precondition"
          },
          "when": {
            "type": "string",
            "description": "User action or trigger"
          },
          "then": {
            "type": "string",
            "description": "Observable outcome"
          }
        }
      }
    },
    "edge_cases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Known edge cases (empty state, error, auth failure, etc.)"
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "What this story explicitly does NOT include"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]{3,4}$"
      },
      "description": "Story IDs that must complete first"
    },
    "owner": {
      "type": "string",
      "enum": ["frontend", "backend", "fullstack", "devops", "qa"],
      "description": "Primary owner role"
    },
    "created_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "updated_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last update timestamp"
    }
  },
  "example": {
    "id": "SES-001",
    "title": "Session lifecycle (DRAFT→LIVE flow)",
    "points": 8,
    "priority": "P1",
    "status": "in_progress",
    "as_a": "session facilitator",
    "i_want": "transition a session from draft to live",
    "so_that": "I can start running the session with participants",
    "acceptance_criteria": [
      {
        "given": "session is in DRAFT state",
        "when": "I click Start",
        "then": "session transitions to LIVE and participants can join"
      },
      {
        "given": "session is LIVE",
        "when": "I try to edit questions",
        "then": "I get a 403 Forbidden error"
      }
    ],
    "edge_cases": [
      "Starting session with 0 questions → error or auto-create placeholder",
      "Network disconnect during transition → rollback to DRAFT",
      "Concurrent start attempts → race condition protection"
    ],
    "out_of_scope": [
      "Presenter view (Sprint 2)",
      "Auto-transition to presenter after start (UX-003)"
    ],
    "dependencies": ["DRAFT-API", "STATUS-SYNC"],
    "owner": "fullstack",
    "created_date": "2026-03-15T10:00:00Z",
    "updated_date": "2026-04-10T14:30:00Z"
  }
}
